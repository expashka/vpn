# Copy to ./codex-vpn.env before install, or answer installer prompts.
# Do not commit real passwords.

VPN_SERVER=212.118.54.47
VPN_IDENTITY=wavesdev
VPN_PASSWORD=change-me

# Linux user whose traffic is always forced through the VPN.
# Run Codex under this user: sudo -iu vpn
VPN_USER=vpn

# Routing table used for policy routing.
TABLE_ID=200
TABLE_NAME=codexvpn

# Root toggle rule prefs used by /usr/local/bin/vpn.
ROOT_PREF=210
ROOT_V6_PREF=211

# Automatically enable root VPN at install time.
# Set to 0 if you only want the vpn user to be routed through VPN.
AUTO_ENABLE_ROOT=1

# Optional container routing.
# Format: space-separated "container_name:ip_rule_pref" entries.
# Example:
# VPN_CONTAINERS="telegram-notify-1:205 codex-sidecar-1:206"
VPN_CONTAINERS=""

# Destinations that should leave via the real server uplink even from VPN-routed
# users/containers. Keep empty for a generic Codex-only server.
# Example VK AS47541:
# DIRECT_CIDRS="87.240.128.0/18 93.186.224.0/20 95.142.192.0/20 95.213.0.0/18"
DIRECT_CIDRS=""

# MSS clamp for selected containers. 1360 is useful for Telegram/API traffic
# over IPsec. It is ignored when VPN_CONTAINERS is empty.
TELEGRAM_MSS=1360

# External IP check used by `vpn status`.
IP_CHECK_URL=https://api.ipify.org
