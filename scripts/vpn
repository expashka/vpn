#!/usr/bin/env bash
set -euo pipefail

CONNECTION="${VPN_CONNECTION:-nl-ikev2}"

usage() {
  echo "Использование: vpn on|off|status"
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "Запустите от root: sudo vpn ${1:-}" >&2
    exit 1
  fi
}

case "${1:-}" in
  on)
    require_root on
    ipsec up "${CONNECTION}"
    ;;
  off)
    require_root off
    ipsec down "${CONNECTION}" 2>/dev/null || true
    echo "VPN ${CONNECTION}: выключен"
    ;;
  status)
    ipsec status "${CONNECTION}"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
